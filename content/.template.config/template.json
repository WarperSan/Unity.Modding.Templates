{
	"$schema": "http://json.schemastore.org/template",
	"name": "BepInEx Plugin",
	"description": "A project structure for doing Unity mods",
	"shortName": "bepinex-plugin-template",
	"author": "WarperSan",
	"identity": "dev.warpersan.bepinex-plugin-template",
	"classifications": [
		"Unity",
		"Plugin",
		"Modding",
		"BepInEx"
	],
	"tags": {
		"language": "C#",
		"type": "project"
	},
	"sourceName": "PluginTemplate",
	"preferNameDirectory": true,
	"symbols": {
		"Author": {
			"type": "parameter",
			"datatype": "text",
			"displayName": "Author",
			"isRequired": true,
			"replaces": "__AUTHOR__"
		},
		"Description": {
			"type": "parameter",
			"datatype": "text",
			"displayName": "Description",
			"defaultValue": "",
			"replaces": "__DESCRIPTION__"
		},
		"Version": {
			"type": "parameter",
			"datatype": "text",
			"displayName": "Initial Version",
			"defaultValue": "1.0.0",
			"replaces": "__VERSION__"
		},
		"Framework": {
			"type": "parameter",
			"datatype": "choice",
			"displayName": "Framework",
			"choices": [
				{
					"choice": "netstandard2.1",
					"displayName": ".NET Standard 2.1"
				},
				{
					"choice": "netstandard2.0",
					"displayName": ".NET Standard 2.0"
				},
				{
					"choice": "net46",
					"displayName": ".NET Framework 4.6"
				},
				{
					"choice": "net35",
					"displayName": ".NET Framework 3.5"
				}
			],
			"enableQuotelessLiterals": true,
			"defaultValue": "netstandard2.1",
			"replaces": "__TARGET_FRAMEWORK__"
		}
	}
}